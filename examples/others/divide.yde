# fun divide function

fun divideiter(x, y, low, high) {
    for i = 0, i < 40, 1 in {
        if (((low + high) * 0.5) * y) < x then {
            low = (low + high) * 0.5;
        } else {
            high = (low + high) * 0.5;
        };
    };
    low;
}

fun divide(x, y) {
    divideiter(x, y, 0.0, 1000.0);
}

fun main() {
    print(divide(10.0, 3.0) + "\n");
    print(divide(2.0, 4.0) + "\n");
}
