# Here's how for loops work in yde

fun multiply(x, y) {
  int result = x;

  # for loop
  for
  # starting by one
  int i = 1, 
  # while i < y
  i < y;
  # add 1 in
  1 in 
  # what the function does
  { result = result + x; };

  # That is:
  # for i = 1, i < y, 1 in { 
  #   x = x + x;
  # };

  result;
}

fun main() {
  print("4 * 10 = " + multiply(4, 10));
  0;
}
